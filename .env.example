# Variables de entorno requeridas para BIOSKIN Admin Panel
# Copia este archivo como .env y completa los valores antes de ejecutar `vercel dev` o `npm run dev`.
# NUNCA subas el archivo .env al repositorio (ya está en .gitignore).

# ─── Base de datos Neon PostgreSQL ──────────────────────────────────────────
# URL de conexión a la base de datos Neon (obtenida desde el dashboard de Neon o Vercel)
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Alternativa si usas Vercel Postgres integrado
POSTGRES_URL=

# ─── Auth (admin-auth.js) ────────────────────────────────────────────────────
# No se necesita una clave extra; el sistema usa PBKDF2+salt con Node crypto nativo.
# La inicialización del master_admin se hace llamando a:
#   GET /api/admin-auth?action=init-schema
# (solo debe ejecutarse una vez en producción)

# ─── Google Calendar / Email ─────────────────────────────────────────────────
# Credenciales de cuenta de servicio Google en Base64
# Generar: base64 -i credentials.json -o credentials.b64
GOOGLE_CREDENTIALS_BASE64=

# Cuenta Gmail para envío de correos (nodemailer)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Usada por módulos de IA (diagnóstico, protocolos, asistente)
# ⚠️  NO usar prefijo VITE_ — esta clave solo se usa en serverless functions
OPENAI_API_KEY=sk-...

# ─── Google Gemini ───────────────────────────────────────────────────────────
# Usada por lib/ai-service.js para análisis de imágenes
GEMINI_API_KEY=

# ─── WhatsApp (interno) ──────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GROUP_ID=

# ─── Internal Bot ────────────────────────────────────────────────────────────
INTERNAL_BOT_SECRET=

# ─── Cron secret (Vercel) ────────────────────────────────────────────────────
CRON_SECRET=
